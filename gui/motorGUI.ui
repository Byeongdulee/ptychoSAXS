    background: #ccc;
    border-radius: 6px;
}

QSlider::handle:horizontal {
    width: 35px;
    height: 18px;
    background: #2196F3;
    border-radius: 9px;
    margin: -3px 0;            /* centers handle vertically on thicker groove */
}

QSlider::sub-page:horizontal {
    background: #66bb6a;       /* filled (left side) */
    border-radius: 6px;
}

QSlider::add-page:horizontal {
    background: #bbb;          /* unfilled (right side) */
    border-radius: 6px;
}</string>
